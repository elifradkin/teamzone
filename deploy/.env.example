# Copy to .env on the server (next to docker-compose.yml). Never commit the real .env.
POSTGRES_USER=teamzone
POSTGRES_PASSWORD=change-me-to-a-long-random-string
POSTGRES_DB=teamzone
SESSION_SECRET=another-long-random-string
# Your server's public IP with dashes, as an sslip.io hostname, for real HTTPS:
#   e.g. https://203-0-113-5.sslip.io
SITE_ADDRESS=https://YOUR-IP-WITH-DASHES.sslip.io
# --- Motra ingestion (keep OFF until Motra grants permission, R-1) ---
TOKEN_ENCRYPTION_KEY=run-openssl-rand-hex-32
APP_BASE_URL=https://YOUR-IP-WITH-DASHES.sslip.io
MOTRA_INGESTION_ENABLED=false
