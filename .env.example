# --- Core ---
DATABASE_URL=
REDIS_URL=
SESSION_SECRET=

# --- Object storage (MinIO) ---
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=

# --- AI (server-side only) ---
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# --- Motra (per-user OAuth via MCP; tokens encrypted at rest) ---
MOTRA_MCP_URL=https://mcp.motra.com/mcp
# 64 hex chars (32 bytes): openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=
# Public base URL for the OAuth redirect (e.g. https://5-78-70-179.sslip.io)
APP_BASE_URL=
# Keep OFF until Motra grants written permission (R-1). "true" to enable.
MOTRA_INGESTION_ENABLED=false

