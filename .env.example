# Copy to .env and fill in. NEVER commit .env.

# Claude API key — https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Models (cost/quality routing). Override if needed.
MODEL_MAIN=claude-sonnet-4-6
MODEL_TRIAGE=claude-haiku-4-5-20251001

# Server
PORT=3000

# Secret used to sign session cookies. Generate a long random string.
SESSION_SECRET=change-me-to-a-long-random-string

# Comma-separated "userId:PIN" pairs for the ~20 users (simple auth).
# Example: AUTH_USERS=eli:1234,dana:5678
AUTH_USERS=demo:1234

# Phase 2 (voice) — leave blank until you wire voice.
OPENAI_API_KEY=
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
ELEVENLABS_API_KEY=
